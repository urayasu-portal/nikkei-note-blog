---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import SiteHeader from '../components/SiteHeader.astro';

type Props = CollectionEntry<'blog'>['data'];

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  heroImage,
  nikkei,
  nikkeiDate,
  topix,
  topixDate,
  usd,
  usdDate,
  dow,
  dowDate,
  nasdaq,
  nasdaqDate,
} = Astro.props;

const categoryLabel =
  category === 'nikkei' ? '日経ノート' :
  category === 'deep' ? '深掘りノート' :
  category === 'memo' ? '投資メモ' :
  category === 'glossary' ? '用語解説' :
  category || '記事';

// カテゴリー別OGP画像（SNSシェア用）
const ogpImageMap: Record<string, string> = {
  nikkei: '/blog-placeholder-1.jpg',
  deep:   '/blog-placeholder-2.jpg',
  memo:   '/blog-placeholder-3.jpg',
  glossary: '/blog-placeholder-4.jpg',
};
const ogpImage = heroImage ?? (category ? ogpImageMap[category] : undefined) ?? '/blog-placeholder-1.jpg';

const formattedDate = pubDate
  ? `${pubDate.getFullYear()}年${pubDate.getMonth() + 1}月${pubDate.getDate()}日`
  : '';
---

<html lang="ja">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={ogpImage}
      type="article"
      pubDate={pubDate}
      updatedDate={updatedDate}
    />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": title,
      "description": description,
      "image": `https://nikkei-note.com${ogpImage}`,
      "datePublished": pubDate?.toISOString(),
      "dateModified": (updatedDate ?? pubDate)?.toISOString(),
      "author": {
        "@type": "Organization",
        "name": "今日の日本株ノート",
        "url": "https://nikkei-note.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "今日の日本株ノート",
        "url": "https://nikkei-note.com"
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": Astro.url.href
      }
    })} />
    <style>
      :root {
        --navy: #10233f;
        --navy-2: #17375f;
        --blue: #eaf2fb;
        --blue-2: #f5f8fc;
        --text: #1f2937;
        --muted: #6b7280;
        --border: #dbe3ef;
        --green: #12805c;
        --red: #c2410c;
        --white: #ffffff;
        --shadow: 0 14px 36px rgba(16, 35, 63, .08);
        --radius: 18px;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body { overflow-x: clip; }

      body {
        font-family: "Meiryo UI", "Meiryo", "Yu Gothic UI", "Yu Gothic", "Hiragino Sans", sans-serif;
        color: var(--text);
        background: linear-gradient(180deg, #f7fbff 0%, #ffffff 38%, #f8fafc 100%);
        line-height: 1.85;
      }

      a { color: inherit; text-decoration: none; }

      /* パンくずリスト上のスペース調整 */

      /* パンくずリスト */
      .breadcrumb {
        max-width: 1200px;
        margin: 0 auto;
        padding: 14px 20px 0;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: var(--muted);
      }

      .breadcrumb a { color: var(--navy); }
      .breadcrumb span { color: var(--muted); }

      /* メインレイアウト */
      .layout {
        max-width: 1200px;
        margin: 24px auto 60px;
        padding: 0 20px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 320px;
        gap: 28px;
        align-items: start;
      }

      /* 記事本文エリア */
      .article-wrap {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      /* 記事ヘッダー */
      .article-header {
        background: linear-gradient(135deg, #10233f 0%, #17375f 58%, #24649c 100%);
        color: #fff;
        padding: 32px 36px;
      }

      .article-meta-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
        flex-wrap: wrap;
      }

      .badge {
        background: rgba(255,255,255,.18);
        border: 1px solid rgba(255,255,255,.3);
        border-radius: 999px;
        padding: 3px 12px;
        font-size: 12px;
        font-weight: 700;
        color: #dcecff;
      }

      .article-date {
        color: #9ec4e8;
        font-size: 13px;
      }

      .article-title {
  font-size: clamp(20px, 3vw, 28px);
  line-height: 1.45;
  font-weight: 800;
  letter-spacing: .02em;
  margin-bottom: 16px;
  color: #ffffff;
}

      .article-description {
        color: #dce7f6;
        font-size: 14px;
        line-height: 1.75;
        max-width: 680px;
      }

      /* 記事本文 */
      .article-body {
        padding: 36px;
      }

      .article-body :global(h2) {
        font-size: 20px;
        color: var(--navy);
        margin: 36px 0 14px;
        padding: 12px 16px;
        background: var(--blue-2);
        border-left: 4px solid var(--navy);
        border-radius: 0 8px 8px 0;
        line-height: 1.5;
      }

      .article-body :global(h2:first-child) {
        margin-top: 0;
      }

      .article-body :global(h3) {
        font-size: 17px;
        color: var(--navy-2);
        margin: 24px 0 10px;
        padding-left: 12px;
        border-left: 3px solid #5b8dd9;
      }

      .article-body :global(p) {
        font-size: 15px;
        color: var(--text);
        margin-bottom: 16px;
        line-height: 1.9;
      }

      .article-body :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: 20px 0;
        font-size: 14px;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--border);
      }

      .article-body :global(th) {
        background: var(--navy);
        color: #fff;
        padding: 10px 14px;
        text-align: left;
        font-weight: 700;
        font-size: 13px;
      }

      .article-body :global(td) {
        padding: 10px 14px;
        border-bottom: 1px solid var(--border);
        vertical-align: top;
      }

      .article-body :global(tr:last-child td) {
        border-bottom: none;
      }

      .article-body :global(tr:nth-child(even) td) {
        background: var(--blue-2);
      }

      .article-body :global(a) {
        color: var(--navy);
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      .article-body :global(ul),
      .article-body :global(ol) {
        padding-left: 1.5em;
        margin-bottom: 16px;
      }

      .article-body :global(li) {
        font-size: 15px;
        margin-bottom: 6px;
        line-height: 1.8;
      }

      /* 深堀へのリンクボックス */
      .deep-link-box {
        background: linear-gradient(135deg, #eaf2fb, #f5f8fc);
        border: 1px solid #c5d9f0;
        border-radius: 14px;
        padding: 20px 24px;
        margin-top: 28px;
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .deep-link-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--navy), #315d91);
        display: grid;
        place-items: center;
        color: #fff;
        font-size: 20px;
        flex-shrink: 0;
      }

      .deep-link-text p {
        margin: 0 0 4px;
        font-size: 13px;
        color: var(--muted);
      }

      .deep-link-text a {
        color: var(--navy);
        font-weight: 700;
        font-size: 14px;
        text-decoration: none;
      }

      /* サイドバー */
      aside {
        display: grid;
        gap: 18px;
        position: sticky;
        top: 80px;
      }

      .side-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
        box-shadow: 0 10px 28px rgba(16,35,63,.05);
      }

      .side-card h3 {
        margin: 0 0 14px;
        color: var(--navy);
        font-size: 16px;
        font-weight: 700;
      }

      /* 相場サマリー */
      .market-list { display: grid; gap: 0; }

      .market-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 9px 0;
        border-bottom: 1px dashed var(--border);
        gap: 12px;
      }

      .market-row:last-child { border-bottom: none; }

      .market-label {
        font-size: 13px;
        color: var(--muted);
      }

      .market-label small {
        display: block;
        font-size: 11px;
        color: #9ca3af;
      }

      .market-value {
        font-weight: 800;
        font-size: 14px;
        color: var(--navy);
        text-align: right;
      }

      .plus { color: var(--green); }
      .minus { color: var(--red); }

      /* 関連記事 */
      .related-list { display: grid; gap: 10px; }

      .related-item {
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 12px;
        transition: box-shadow .15s;
        display: block;
      }

      .related-item:hover { box-shadow: var(--shadow); }

      .related-meta {
        font-size: 11px;
        color: var(--muted);
        margin-bottom: 4px;
      }

      .related-item h4 {
        font-size: 13px;
        color: var(--navy);
        line-height: 1.5;
      }

      /* フッター */
      footer {
        background: var(--navy);
        color: #dce7f6;
        padding: 28px 20px;
      }

      .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
        font-size: 13px;
      }

      .footer-inner a { color: #9ec4e8; }

      /* テーブルのはみ出し防止 */
      .article-body :global(table) {
        display: block;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      /* レスポンシブ */
      @media (max-width: 860px) {
        .layout { grid-template-columns: 1fr; }
        aside { position: static; }
        nav { display: none; }
        .article-header { padding: 24px 18px; }
        .article-body { padding: 22px 18px; }
        .article-body :global(h2) { font-size: 18px; padding: 10px 14px; }
        .article-body :global(h3) { font-size: 16px; }
        .article-body :global(p) { font-size: 16px; line-height: 1.85; }
        .article-body :global(li) { font-size: 16px; }
      }
    </style>
  </head>

  <body>

    <SiteHeader currentCategory={category} />

    <div class="breadcrumb">
      <a href="/">ホーム</a>
      <span>›</span>
      <a href="/blog">記事一覧</a>
      <span>›</span>
      <span>{categoryLabel}</span>
    </div>

    <div class="layout">

      <!-- 記事本文 -->
      <main>
        <article class="article-wrap">

          <div class="article-header">
            <div class="article-meta-row">
              <span class="badge">{categoryLabel}</span>
              <span class="article-date">{formattedDate}</span>
            </div>
            <h1 class="article-title">{title}</h1>
            {description && <p class="article-description">{description}</p>}
          </div>

          <div class="article-body">
            <slot />
          </div>

        </article>
      </main>

      <!-- サイドバー -->
      <aside>

        <!-- 相場サマリー（日経ノートのみ表示） -->
        {category === 'nikkei' && nikkei && (
          <div class="side-card">
            <h3>この日の相場サマリー</h3>
            <div class="market-list">
              <div class="market-row">
                <span class="market-label">日経平均<small>{nikkeiDate}終値</small></span>
                <span class="market-value">{nikkei}</span>
              </div>
              <div class="market-row">
                <span class="market-label">TOPIX<small>{topixDate}終値</small></span>
                <span class="market-value">{topix}</span>
              </div>
              <div class="market-row">
                <span class="market-label">ドル円<small>{usdDate} 15時30分</small></span>
                <span class="market-value">{usd}</span>
              </div>
              <div class="market-row">
                <span class="market-label">NYダウ<small>{dowDate}終値</small></span>
                <span class="market-value">{dow}</span>
              </div>
              <div class="market-row">
                <span class="market-label">NASDAQ<small>{nasdaqDate}終値</small></span>
                <span class="market-value">{nasdaq}</span>
              </div>
            </div>
          </div>
        )}

        <!-- トップへ戻る -->
        <div class="side-card">
          <h3>ナビゲーション</h3>
          <div class="related-list">
            <a class="related-item" href="/">
              <div class="related-meta">トップページ</div>
              <h4>今日の日本株ノート ホームへ</h4>
            </a>
            <a class="related-item" href="/blog">
              <div class="related-meta">記事一覧</div>
              <h4>全記事を見る</h4>
            </a>
          </div>
        </div>

      </aside>
    </div>

    <footer>
      <div class="footer-inner">
        <div>© 今日の日本株ノート</div>
        <div>
          <a href="/about">このサイトについて</a>｜
          <a href="/privacy">プライバシーポリシー</a>｜
          <a href="/contact">お問い合わせ</a>
        </div>
      </div>
    </footer>

  </body>
</html>
