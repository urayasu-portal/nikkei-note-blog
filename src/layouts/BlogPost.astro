---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import SiteHeader from '../components/SiteHeader.astro';
import AffiliateCTA from '../components/AffiliateCTA.astro';
import SiteFooter from '../components/SiteFooter.astro';

type Props = CollectionEntry<'blog'>['data'] & { readTimeMin?: number };

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  heroImage,
  nikkei,
  nikkeiDate,
  topix,
  topixDate,
  usd,
  usdDate,
  dow,
  dowDate,
  nasdaq,
  nasdaqDate,
  readTimeMin,
} = Astro.props;

const categoryLabel =
  category === 'nikkei' ? '日経ノート' :
  category === 'deep' ? '深掘りノート' :
  category === 'memo' ? '投資メモ' :
  category === 'glossary' ? '用語解説' :
  category === 'weekly' ? '週次振り返り' :
  category || '記事';

const formattedDate = pubDate
  ? `${pubDate.getFullYear()}年${pubDate.getMonth() + 1}月${pubDate.getDate()}日`
  : '';

// '68557.73' → '68,557.73'（桁区切り。数値でなければそのまま）
const fmtNum = (s?: string) => {
  if (!s) return '';
  const n = Number(s);
  if (!isFinite(n)) return s;
  const dec = s.split('.')[1]?.length ?? 0;
  return n.toLocaleString('ja-JP', { minimumFractionDigits: dec, maximumFractionDigits: dec });
};

// URL から slug を抽出してコンパニオン記事を検索
const currentPath = Astro.url.pathname;
const currentSlug = currentPath.replace(/^\/blog\//, '').replace(/\/$/, '');

// OGP画像：slug があれば生成済みPNGを使用、なければプレースホルダー
const ogpImage = currentSlug
  ? `/og/${currentSlug}.png`
  : (heroImage ?? '/blog-placeholder-1.jpg');
const datePrefix = currentSlug.match(/^(\d{8})/)?.[1] ?? '';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 通常版 ↔ 深掘り版のコンパニオン記事
let companionPost: CollectionEntry<'blog'> | undefined;
if (datePrefix) {
  if (category === 'nikkei') {
    companionPost = allPosts.find(p => p.id === `${datePrefix}-deep`);
  } else if (category === 'deep') {
    companionPost = allPosts.find(p => p.id === `${datePrefix}-nikkei`);
  }
}

// 同カテゴリーの関連記事（現在記事を除く最新3件）
const relatedPosts = allPosts
  .filter(p => p.data.category === category && p.id !== currentSlug)
  .slice(0, 3);

// 用語解説記事（タグ関連を優先、なければ最新）
const currentTags = (Astro.props.tags ?? []) as string[];
const allGlossary = allPosts.filter(p => p.data.category === 'glossary');
const tagRelatedGlossary = allGlossary.filter(p =>
  p.data.tags?.some(t => currentTags.includes(t))
).slice(0, 4);
const glossaryPosts = tagRelatedGlossary.length >= 2
  ? tagRelatedGlossary
  : allGlossary.slice(0, 4);

// 前後の記事（同カテゴリー）
const sameCatPosts = allPosts.filter(p => p.data.category === category);
const currentIdx = sameCatPosts.findIndex(p => p.id === currentSlug);
const prevPost = currentIdx >= 0 && currentIdx < sameCatPosts.length - 1 ? sameCatPosts[currentIdx + 1] : undefined;
const nextPost = currentIdx > 0 ? sameCatPosts[currentIdx - 1] : undefined;
---

<html lang="ja">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={ogpImage}
      type="article"
      pubDate={pubDate}
      updatedDate={updatedDate}
    />

    <!-- Article 構造化データ -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "image": `https://nikkei-note.com${ogpImage}`,
      "url": Astro.url.href,
      "datePublished": pubDate?.toISOString(),
      "dateModified": (updatedDate ?? pubDate)?.toISOString(),
      "author": {
        "@type": "Person",
        "name": "MK"
      },
      "publisher": {
        "@type": "Organization",
        "name": "今日の日本株ノート",
        "url": "https://nikkei-note.com"
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": Astro.url.href
      }
    })} />

    <!-- BreadcrumbList 構造化データ -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://nikkei-note.com/" },
        { "@type": "ListItem", "position": 2, "name": categoryLabel, "item": `https://nikkei-note.com/blog/category/${category ?? 'nikkei'}/` },
        { "@type": "ListItem", "position": 3, "name": title, "item": Astro.url.href }
      ]
    })} />

    <style>
      :root {
        --navy: #10233f;
        --navy-2: #2c4a74;
        --blue: #eaf2fb;
        --blue-2: #f5f8fc;
        --text: #1c2534;
        --muted: #5d6b80;
        --border: #e2e7ee;
        --green: #0d7a55;
        --red: #c2410c;
        --white: #ffffff;
        --shadow: 0 1px 2px rgba(16, 35, 63, .05);
        --radius: 10px;
        --serif: "Noto Serif JP", "Yu Mincho", "Hiragino Mincho ProN", serif;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { overflow-x: hidden; max-width: 100%; }
      body { overflow-x: hidden; max-width: 100%; }
      body {
        font-family: "Hiragino Kaku Gothic ProN", "Hiragino Sans", "Yu Gothic Medium", "Yu Gothic", "Noto Sans JP", "Meiryo", sans-serif;
        color: var(--text);
        background: #f7f9fb;
        line-height: 1.85;
      }
      a { color: inherit; text-decoration: none; }

      /* パンくずリスト */
      .breadcrumb {
        max-width: 1200px;
        margin: 0 auto;
        padding: 14px 20px 0;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: var(--muted);
        flex-wrap: wrap;
      }
      .breadcrumb a { color: var(--navy); }
      .breadcrumb span { color: var(--muted); }

      /* メインレイアウト */
      .layout {
        max-width: 1200px;
        margin: 24px auto 60px;
        padding: 0 20px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 320px;
        gap: 28px;
        align-items: start;
      }

      /* 記事本文エリア */
      .article-wrap {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      /* 記事ヘッダー（白のエディトリアルヘッダー） */
      .article-header {
        background: var(--white);
        color: var(--text);
        padding: 34px 36px 24px;
        border-bottom: 1px solid var(--border);
      }
      .article-meta-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
        flex-wrap: wrap;
      }
      .badge {
        background: var(--navy);
        border-radius: 3px;
        padding: 2px 11px;
        font-size: 11.5px;
        font-weight: 700;
        letter-spacing: .05em;
        color: #ffffff;
      }
      .article-date {
        color: var(--muted);
        font-size: 13px;
      }
      .read-time {
        color: var(--muted);
        font-size: 12px;
        padding: 2px 8px;
        border: 1px solid var(--border);
        border-radius: 999px;
      }
      .article-title {
        font-family: var(--serif);
        font-size: clamp(22px, 3vw, 30px);
        line-height: 1.55;
        font-weight: 700;
        letter-spacing: .01em;
        margin-bottom: 14px;
        color: var(--navy);
        text-wrap: balance;
      }
      .article-description {
        color: var(--muted);
        font-size: 14px;
        line-height: 1.8;
        max-width: 680px;
      }

      /* 相場チップ列（frontmatterに指標があるときのみ） */
      .market-chips {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        padding: 18px 36px 0;
      }
      .mchip {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 7px 14px;
        display: flex;
        flex-direction: column;
      }
      .mchip-l {
        font-size: 10.5px;
        color: var(--muted);
      }
      .mchip-v {
        font-size: 14px;
        font-weight: 700;
        color: var(--navy);
        font-variant-numeric: tabular-nums;
      }

      /* コンパニオン記事リンク（通常版↔深掘り版） */
      .companion-box {
        display: flex;
        align-items: center;
        gap: 16px;
        background: #f2f7fc;
        border: 1px solid var(--border);
        border-left: 3px solid var(--navy);
        border-radius: 0 8px 8px 0;
        padding: 16px 20px;
        margin: 24px 36px 0;
      }
      .companion-icon {
        width: 38px;
        height: 38px;
        border-radius: 6px;
        background: var(--navy);
        display: grid;
        place-items: center;
        color: #fff;
        font-size: 16px;
        flex-shrink: 0;
        font-weight: 700;
        font-family: var(--serif);
      }
      .companion-label {
        font-size: 12px;
        color: var(--muted);
        margin-bottom: 4px;
      }
      .companion-link {
        color: var(--navy);
        font-weight: 700;
        font-size: 14px;
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      /* 記事本文 */
      .article-body {
        padding: 36px;
      }
      .article-body :global(h2) {
        font-family: var(--serif);
        font-size: 21px;
        font-weight: 700;
        color: var(--navy);
        margin: 38px 0 14px;
        padding: 14px 28px 0 0;
        border-top: 2px solid var(--navy);
        display: inline-block;
        line-height: 1.6;
      }
      .article-body :global(h2:first-child) { margin-top: 0; }
      .article-body :global(h3) {
        font-size: 16.5px;
        color: var(--navy-2);
        margin: 24px 0 10px;
        padding-left: 12px;
        border-left: 3px solid #c9d8ea;
      }
      .article-body :global(p) {
        font-size: 15px;
        color: var(--text);
        margin-bottom: 16px;
        line-height: 1.9;
      }
      .article-body :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: 20px 0;
        font-size: 14px;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--border);
        display: block;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }
      .article-body :global(th) {
        background: var(--navy);
        color: #fff;
        padding: 10px 14px;
        text-align: left;
        font-weight: 700;
        font-size: 13px;
        white-space: nowrap;
      }
      .article-body :global(td) {
        padding: 10px 14px;
        border-bottom: 1px solid var(--border);
        vertical-align: top;
      }
      .article-body :global(tr:last-child td) { border-bottom: none; }
      .article-body :global(tr:nth-child(even) td) { background: var(--blue-2); }
      .article-body :global(a) {
        color: var(--navy);
        text-decoration: underline;
        text-underline-offset: 3px;
      }
      .article-body :global(ul),
      .article-body :global(ol) {
        padding-left: 1.5em;
        margin-bottom: 16px;
      }
      .article-body :global(li) {
        font-size: 15px;
        margin-bottom: 6px;
        line-height: 1.8;
      }
      .article-body :global(hr) {
        border: none;
        border-top: 1px solid var(--border);
        margin: 28px 0;
      }
      .article-body :global(strong) { color: var(--navy); }

      /* 記事末尾のコンパニオンリンク */
      .companion-bottom {
        display: flex;
        align-items: center;
        gap: 14px;
        background: var(--navy);
        color: #fff;
        border-radius: 8px;
        padding: 20px 24px;
        margin-top: 32px;
        text-decoration: none;
      }
      .companion-bottom-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: rgba(255,255,255,.15);
        display: grid;
        place-items: center;
        font-size: 16px;
        font-weight: 900;
        flex-shrink: 0;
      }
      .companion-bottom-label {
        font-size: 11px;
        color: #9ec4e8;
        margin-bottom: 3px;
      }
      .companion-bottom-title {
        font-size: 14px;
        font-weight: 700;
        color: #fff;
        line-height: 1.5;
      }

      /* 関連記事セクション */
      .related-section {
        border-top: 1px solid var(--border);
        margin-top: 36px;
        padding-top: 28px;
      }
      .related-section h3 {
        font-size: 17px;
        color: var(--navy);
        margin-bottom: 16px;
        font-weight: 800;
      }
      .related-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 12px;
      }
      .related-card {
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 14px;
        display: block;
        transition: box-shadow .15s, transform .15s;
        background: var(--white);
      }
      .related-card:hover {
        box-shadow: var(--shadow);
        transform: translateY(-2px);
      }
      .related-badge {
        font-size: 11px;
        font-weight: 700;
        color: var(--navy-2);
        background: var(--blue);
        border-radius: 999px;
        padding: 2px 8px;
        display: inline-block;
        margin-bottom: 6px;
      }
      .related-title {
        font-size: 13px;
        color: var(--navy);
        line-height: 1.55;
        font-weight: 600;
      }

      /* 用語解説リンク */
      .glossary-section {
        border-top: 1px solid var(--border);
        margin-top: 24px;
        padding-top: 20px;
      }
      .glossary-section h3 {
        font-size: 15px;
        color: var(--navy);
        margin-bottom: 12px;
        font-weight: 700;
      }
      .glossary-links {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .glossary-link {
        font-size: 13px;
        color: var(--navy);
        background: var(--blue);
        border: 1px solid #c5d9f0;
        border-radius: 999px;
        padding: 5px 14px;
        transition: background .15s;
      }
      .glossary-link:hover { background: #d5e8f8; }

      /* 前後記事ナビ */
      .post-nav {
        border-top: 1px solid var(--border);
        margin-top: 28px;
        padding-top: 20px;
      }
      .post-nav-inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
      .post-nav-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 14px 16px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--white);
        transition: box-shadow .15s;
      }
      .post-nav-item:hover { box-shadow: var(--shadow); }
      .post-nav-next { text-align: right; }
      .post-nav-label {
        font-size: 11px;
        color: var(--muted);
      }
      .post-nav-title {
        font-size: 13px;
        font-weight: 700;
        color: var(--navy);
        line-height: 1.5;
      }
      @media (max-width: 860px) {
        .post-nav-inner { grid-template-columns: 1fr; }
      }

      /* サイドバー */
      aside {
        display: grid;
        gap: 18px;
        position: sticky;
        top: 80px;
      }
      .side-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
        box-shadow: 0 10px 28px rgba(16,35,63,.05);
      }
      .side-card h3 {
        margin: 0 0 14px;
        color: var(--navy);
        font-size: 16px;
        font-weight: 700;
      }

      /* 相場サマリー */
      .market-list { display: grid; gap: 0; }
      .market-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 9px 0;
        border-bottom: 1px dashed var(--border);
        gap: 12px;
      }
      .market-row:last-child { border-bottom: none; }
      .market-label {
        font-size: 13px;
        color: var(--muted);
      }
      .market-label small {
        display: block;
        font-size: 11px;
        color: #9ca3af;
      }
      .market-value {
        font-weight: 800;
        font-size: 14px;
        color: var(--navy);
        text-align: right;
        font-variant-numeric: tabular-nums;
      }
      .plus { color: var(--green); }
      .minus { color: var(--red); }

      /* サイドの関連記事 */
      .related-list { display: grid; gap: 10px; }
      .related-item {
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 12px;
        transition: box-shadow .15s;
        display: block;
      }
      .related-item:hover { box-shadow: var(--shadow); }
      .related-meta {
        font-size: 11px;
        color: var(--muted);
        margin-bottom: 4px;
      }
      .related-item h4 {
        font-size: 13px;
        color: var(--navy);
        line-height: 1.5;
      }

      /* フッター */
      footer {
        background: var(--navy);
        color: #dce7f6;
        padding: 28px 20px;
      }
      .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
        font-size: 13px;
      }
      .footer-inner a { color: #9ec4e8; }
      .footer-disclaimer {
        max-width: 1200px;
        margin: 14px auto 0;
        font-size: 12px;
        line-height: 1.7;
        color: #9ec4e8;
      }

      /* レスポンシブ */
      @media (max-width: 860px) {
        /* 全要素の横幅を viewport 内に収める */
        .breadcrumb,
        .layout,
        .article-wrap,
        .article-header,
        .companion-box,
        .article-body,
        aside {
          max-width: 100%;
          width: 100%;
        }

        .layout {
          grid-template-columns: 1fr;
          padding: 0 12px;
          margin-top: 12px;
          margin-bottom: 32px;
        }
        aside { position: static; }

        /* 長いテキストを強制折り返し */
        .article-title,
        .article-description,
        .companion-link,
        .companion-bottom-title,
        .article-body :global(*) {
          word-break: break-word;
          overflow-wrap: anywhere;
        }

        /* ① descriptionをモバイルで非表示 */
        .article-description { display: none; }

        /* ヘッダー */
        .article-header { padding: 20px 16px 16px; }
        .article-title { font-size: 20px; }
        .market-chips { padding: 14px 16px 0; }

        /* ② パンくずの記事タイトルを非表示 */
        .breadcrumb-title { display: none; }
        .breadcrumb-sep-title { display: none; }
        .breadcrumb { padding: 10px 12px 0; }

        /* ③ コンパニオンボックスをスリム化 */
        .companion-box {
          margin: 10px 0 0;
          padding: 9px 12px;
          border-radius: 0 8px 8px 0;
          border: none;
          border-left: 3px solid #5b8dd9;
          background: #f0f6fd;
          gap: 10px;
        }
        .companion-icon { width: 28px; height: 28px; border-radius: 7px; font-size: 12px; }
        .companion-label { font-size: 11px; margin-bottom: 2px; }
        .companion-link { font-size: 13px; }

        /* ④ 本文フォントサイズ */
        .article-body { padding: 18px 16px; }
        .article-body :global(h2) { font-size: 18px; padding: 12px 20px 0 0; margin: 26px 0 10px; }
        .article-body :global(h3) { font-size: 15px; }
        .article-body :global(p) { font-size: 15px; line-height: 1.85; margin-bottom: 14px; }
        .article-body :global(li) { font-size: 15px; }

        .related-grid { grid-template-columns: 1fr; }

        /* モバイルでは重複するサイドバーカード（コンパニオン＝本文内に既出／ナビ＝ヘッダーに既出）を隠す */
        .side-hide-mobile { display: none; }
      }
    </style>
  </head>

  <body>
    <SiteHeader currentCategory={category} />

    <!-- パンくずリスト -->
    <div class="breadcrumb">
      <a href="/">ホーム</a>
      <span>›</span>
      <a href="/blog">記事一覧</a>
      <span>›</span>
      <a href={`/blog/category/${category ?? 'nikkei'}`}>{categoryLabel}</a>
      <span class="breadcrumb-sep-title">›</span>
      <span class="breadcrumb-title">{title}</span>
    </div>

    <div class="layout">

      <!-- 記事本文 -->
      <main>
        <article class="article-wrap">

          <!-- 記事ヘッダー -->
          <div class="article-header">
            <div class="article-meta-row">
              <span class="badge">{categoryLabel}</span>
              <span class="article-date">{formattedDate}</span>
              {updatedDate && (
                <span class="article-date">更新: {updatedDate.getFullYear()}年{updatedDate.getMonth() + 1}月{updatedDate.getDate()}日</span>
              )}
              {readTimeMin && (
                <span class="read-time">約{readTimeMin}分で読めます</span>
              )}
            </div>
            <h1 class="article-title">{title}</h1>
            {description && <p class="article-description">{description}</p>}
          </div>

          <!-- 相場チップ列（指標データがある記事のみ） -->
          {(nikkei || topix || usd || dow || nasdaq) && (
            <div class="market-chips">
              {nikkei && (
                <div class="mchip">
                  <span class="mchip-l">日経平均</span>
                  <span class="mchip-v">{fmtNum(nikkei)}</span>
                </div>
              )}
              {topix && (
                <div class="mchip">
                  <span class="mchip-l">TOPIX</span>
                  <span class="mchip-v">{fmtNum(topix)}</span>
                </div>
              )}
              {usd && (
                <div class="mchip">
                  <span class="mchip-l">ドル円</span>
                  <span class="mchip-v">{fmtNum(usd)}</span>
                </div>
              )}
              {dow && (
                <div class="mchip">
                  <span class="mchip-l">NYダウ</span>
                  <span class="mchip-v">{fmtNum(dow)}</span>
                </div>
              )}
              {nasdaq && (
                <div class="mchip">
                  <span class="mchip-l">NASDAQ</span>
                  <span class="mchip-v">{fmtNum(nasdaq)}</span>
                </div>
              )}
            </div>
          )}

          <!-- 通常版↔深掘り版 コンパニオンリンク（上部） -->
          {companionPost && (
            <div class="companion-box">
              <div class="companion-icon">
                {category === 'nikkei' ? '深' : '3'}
              </div>
              <div>
                <p class="companion-label">
                  {category === 'nikkei' ? 'さらに詳しく読む：深掘りノート' : '短く確認する：日経ノート（3分）'}
                </p>
                <a class="companion-link" href={`/blog/${companionPost.id}/`}>
                  {companionPost.data.title}
                </a>
              </div>
            </div>
          )}

          <!-- 記事本文 -->
          <div class="article-body">
            <slot />

            <!-- 通常版↔深掘り版 コンパニオンリンク（本文末尾） -->
            {companionPost && (
              <a class="companion-bottom" href={`/blog/${companionPost.id}/`}>
                <div class="companion-bottom-icon">
                  {category === 'nikkei' ? '深' : '3'}
                </div>
                <div>
                  <div class="companion-bottom-label">
                    {category === 'nikkei' ? 'さらに詳しく読む' : '短く確認する（約3分）'}
                  </div>
                  <div class="companion-bottom-title">{companionPost.data.title}</div>
                </div>
              </a>
            )}

            <!-- アフィリエイトCTA（nikkei・deep記事のみ）: 読了直後の熱があるうちに配置 -->
            {(category === 'nikkei' || category === 'deep') && (
              <AffiliateCTA
                category="securities"
                heading="ネット証券で口座を開くなら"
                lead="毎日の相場チェックや実際の売買には、使いやすいネット証券口座があると便利です。日本株の取引に定評のある2社を紹介します。"
              />
            )}

            <!-- 関連記事 -->
            {relatedPosts.length > 0 && (
              <div class="related-section">
                <h3>あわせて読む</h3>
                <div class="related-grid">
                  {relatedPosts.map(post => (
                    <a class="related-card" href={`/blog/${post.id}/`}>
                      <div class="related-badge">{
                        post.data.category === 'nikkei' ? '日経ノート' :
                        post.data.category === 'deep' ? '深掘りノート' :
                        post.data.category === 'memo' ? '投資メモ' :
                        post.data.category === 'glossary' ? '用語解説' :
                        post.data.category === 'weekly' ? '週次振り返り' :
                        post.data.category ?? '記事'
                      }</div>
                      <div class="related-title">{post.data.title}</div>
                    </a>
                  ))}
                </div>
              </div>
            )}

            <!-- 用語解説リンク -->
            {glossaryPosts.length > 0 && (
              <div class="glossary-section">
                <h3>用語解説を確認する</h3>
                <div class="glossary-links">
                  {glossaryPosts.map(post => (
                    <a class="glossary-link" href={`/blog/${post.id}/`}>{post.data.title.replace(/とは.*/, '').replace(/？.*/, '')}</a>
                  ))}
                </div>
              </div>
            )}

            <!-- 前後記事ナビ -->
            {(prevPost || nextPost) && (
              <div class="post-nav">
                <div class="post-nav-inner">
                  {prevPost ? (
                    <a class="post-nav-item post-nav-prev" href={`/blog/${prevPost.id}/`}>
                      <span class="post-nav-label">← 前の記事</span>
                      <span class="post-nav-title">{prevPost.data.title}</span>
                    </a>
                  ) : <div />}
                  {nextPost ? (
                    <a class="post-nav-item post-nav-next" href={`/blog/${nextPost.id}/`}>
                      <span class="post-nav-label">次の記事 →</span>
                      <span class="post-nav-title">{nextPost.data.title}</span>
                    </a>
                  ) : <div />}
                </div>
              </div>
            )}

          </div>
        </article>
      </main>

      <!-- サイドバー -->
      <aside>

        <!-- 相場サマリー（日経ノートのみ表示。モバイルは冒頭チップと重複するため非表示） -->
        {category === 'nikkei' && nikkei && (
          <div class="side-card side-hide-mobile">
            <h3>この日の相場サマリー</h3>
            <div class="market-list">
              {nikkei && (
                <div class="market-row">
                  <span class="market-label">日経平均<small>{nikkeiDate}終値</small></span>
                  <span class="market-value">{fmtNum(nikkei)}</span>
                </div>
              )}
              {topix && (
                <div class="market-row">
                  <span class="market-label">TOPIX<small>{topixDate}終値</small></span>
                  <span class="market-value">{fmtNum(topix)}</span>
                </div>
              )}
              {usd && (
                <div class="market-row">
                  <span class="market-label">ドル円<small>{(usdDate ?? '').split('T')[0]} 15時30分</small></span>
                  <span class="market-value">{fmtNum(usd)}</span>
                </div>
              )}
              {dow && (
                <div class="market-row">
                  <span class="market-label">NYダウ<small>{dowDate}終値</small></span>
                  <span class="market-value">{fmtNum(dow)}</span>
                </div>
              )}
              {nasdaq && (
                <div class="market-row">
                  <span class="market-label">NASDAQ<small>{nasdaqDate}終値</small></span>
                  <span class="market-value">{fmtNum(nasdaq)}</span>
                </div>
              )}
            </div>
          </div>
        )}

        <!-- コンパニオン記事（サイドバー） -->
        {companionPost && (
          <div class="side-card side-hide-mobile">
            <h3>{category === 'nikkei' ? '深掘りノート' : '日経ノート（3分）'}</h3>
            <div class="related-list">
              <a class="related-item" href={`/blog/${companionPost.id}/`}>
                <div class="related-meta">
                  {category === 'nikkei' ? '詳しく読む' : '短く確認する'}
                </div>
                <h4>{companionPost.data.title}</h4>
              </a>
            </div>
          </div>
        )}

        <!-- ナビゲーション -->
        <div class="side-card side-hide-mobile">
          <h3>ナビゲーション</h3>
          <div class="related-list">
            <a class="related-item" href="/">
              <div class="related-meta">トップページ</div>
              <h4>今日の日本株ノート ホームへ</h4>
            </a>
            <a class="related-item" href="/blog">
              <div class="related-meta">記事一覧</div>
              <h4>全記事を見る</h4>
            </a>
            <a class="related-item" href="/blog/category/nikkei">
              <div class="related-meta">カテゴリー</div>
              <h4>日経ノート一覧</h4>
            </a>
            <a class="related-item" href="/blog/category/deep">
              <div class="related-meta">カテゴリー</div>
              <h4>深掘りノート一覧</h4>
            </a>
          </div>
        </div>

      </aside>
    </div>

    <SiteFooter />

  </body>
</html>
