---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import CalendarWidget from '../components/CalendarWidget.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const latestPost = posts[0];
const recentPosts = posts.slice(1, 7);

// 用語解説
const glossaryPosts  = posts.filter(p => p.data.category === 'glossary');
const glossaryCount  = glossaryPosts.length;
const latestGlossary = glossaryPosts.slice(0, 3);

// 最新の日経ノートを取得（相場データの供給元）
const latestNikkeiNote = posts.find(post => post.data.category === 'nikkei');
const md = latestNikkeiNote?.data;

// weeklyThemes / checkPoints を持つ最新記事から取得（なければデフォルト値）
const latestWithThemes = posts.find(p => p.data.weeklyThemes && p.data.weeklyThemes.length > 0);
const weeklyThemes = latestWithThemes?.data.weeklyThemes ?? ['決算発表','為替','半導体','銀行株','米金利'];

const latestWithCP = posts.find(p => p.data.checkPoints && p.data.checkPoints.length > 0);
const checkPoints = latestWithCP?.data.checkPoints ?? [
  { title: '米国市場',  text: 'NASDAQと米長期金利の方向感を確認。' },
  { title: '為替',      text: '輸出株・内需株への影響をざっくり整理。' },
  { title: '決算・材料', text: '寄り付き前に注目テーマを把握。' },
];

// カテゴリー集計
const categoryMap: Record<string, { label: string; href: string }> = {
  nikkei:   { label: '日経ノート',   href: '/blog/category/nikkei' },
  deep:     { label: '深掘りノート', href: '/blog/category/deep' },
  weekly:   { label: '週次まとめ',   href: '/blog/category/weekly' },
  memo:     { label: '投資メモ',     href: '/blog/category/memo' },
  glossary: { label: '用語解説',     href: '/blog/category/glossary' },
};
const categoryCounts: Record<string, { label: string; href: string; count: number }> = {};
posts.forEach(post => {
  const key = post.data.category || '';
  const info = categoryMap[key] ?? { label: '未分類', href: '/blog' };
  if (!categoryCounts[key]) categoryCounts[key] = { ...info, count: 0 };
  categoryCounts[key].count += 1;
});

// ---- 表示用ヘルパー ----
const youbi = ['日','月','火','水','木','金','土'];

// ISO日時が混ざっていても日付部分だけ取り出す（usdDate対策）
const fmtD = (s?: string) => (s ?? '').split('T')[0];

// '68557.73' → '68,557.73'（桁区切り。数値でなければそのまま）
const fmtNum = (s?: string) => {
  if (!s) return '';
  const n = Number(s);
  if (!isFinite(n)) return s;
  const dec = s.split('.')[1]?.length ?? 0;
  return n.toLocaleString('ja-JP', { minimumFractionDigits: dec, maximumFractionDigits: dec });
};

// '2026-07-10' → '7月10日（金）'
const jpDate = (s?: string) => {
  const d = fmtD(s);
  const dt = d ? new Date(d) : undefined;
  if (!dt || isNaN(dt.valueOf())) return '';
  return `${dt.getMonth() + 1}月${dt.getDate()}日（${youbi[dt.getDay()]}）`;
};

// Date → '7/10 金'
const rowDate = (dt: Date) => `${dt.getMonth() + 1}/${dt.getDate()} ${youbi[dt.getDay()]}`;

// '2026-07-09' → '7/9'
const shortMD = (s?: string) => {
  const d = fmtD(s);
  const m = d.match(/^\d{4}-(\d{2})-(\d{2})/);
  return m ? `${Number(m[1])}/${Number(m[2])}` : d;
};

// 「【…】…｜見出し」→「見出し」（用語解説は「〇〇とは｜…」形式のため対象外）
const stripTitle = (t: string, category?: string) => {
  if (category === 'glossary') return t;
  const i = t.indexOf('｜');
  return i >= 0 ? t.slice(i + 1) : t;
};

const catBadge: Record<string, { label: string; cls: string }> = {
  nikkei:   { label: '日経ノート', cls: 'b-nk' },
  deep:     { label: '深掘り',     cls: 'b-dp' },
  memo:     { label: '投資メモ',   cls: 'b-mm' },
  weekly:   { label: '週次まとめ', cls: 'b-wk' },
  glossary: { label: '用語解説',   cls: 'b-gl' },
};

const leadDate = latestPost
  ? `${latestPost.data.pubDate.getFullYear()}年${latestPost.data.pubDate.getMonth() + 1}月${latestPost.data.pubDate.getDate()}日（${youbi[latestPost.data.pubDate.getDay()]}）`
  : '';
const leadBadge = latestPost ? (catBadge[latestPost.data.category ?? ''] ?? { label: '最新', cls: 'b-nk' }) : undefined;

// リード記事が日経ノートなら深掘り版コンパニオンを探す
const leadDatePrefix = latestPost?.id.match(/^(\d{8})/)?.[1];
const leadCompanionDeep = latestPost?.data.category === 'nikkei' && leadDatePrefix
  ? posts.find(p => p.id === `${leadDatePrefix}-deep`)
  : undefined;
---
<!doctype html>
<html lang="ja">
<head>
  <BaseHead
    title="今日の日本株ノート"
    description="毎日の日本株市場を、むずかしすぎず・軽すぎず整理する相場ノート"
    image="/blog-placeholder-1.jpg"
  />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "今日の日本株ノート",
    "url": "https://nikkei-note.com",
    "description": "毎日の日本株市場を、むずかしすぎず・軽すぎず整理する相場ノート",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://nikkei-note.com/blog/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />
  <style>
    :root {
      --navy: #10233f;
      --navy-2: #2c4a74;
      --blue: #eaf2fb;
      --blue-2: #f5f8fc;
      --text: #1c2534;
      --muted: #5d6b80;
      --border: #e2e7ee;
      --green: #0d7a55;
      --red: #c2410c;
      --white: #ffffff;
      --serif: "Noto Serif JP", "Yu Mincho", "Hiragino Mincho ProN", serif;
    }
    * { box-sizing: border-box; }
    html { overflow-x: hidden; }
    body {
      margin: 0;
      font-family: "Hiragino Kaku Gothic ProN", "Hiragino Sans", "Yu Gothic Medium", "Yu Gothic", "Noto Sans JP", "Meiryo", sans-serif;
      color: var(--text);
      background: #f7f9fb;
      line-height: 1.8;
      overflow-x: clip;
    }
    a { color: inherit; text-decoration: none; }
    .num { font-variant-numeric: tabular-nums; }

    /* ===== マストヘッド ===== */
    header {
      position: sticky;
      top: 0;
      z-index: 100;
      backdrop-filter: blur(12px);
      background: rgba(255,255,255,.94);
      border-bottom: 1px solid var(--border);
    }
    .header-inner {
      max-width: 1160px;
      margin: 0 auto;
      padding: 14px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      font-family: var(--serif);
      font-weight: 700;
      color: var(--navy);
      font-size: 18px;
      letter-spacing: .04em;
      white-space: nowrap;
    }
    .brand-icon {
      width: 32px;
      height: 32px;
      border-radius: 6px;
      background: var(--navy);
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 15px;
      font-weight: 700;
      flex-shrink: 0;
    }
    nav {
      display: flex;
      gap: 20px;
      color: #374151;
      font-size: 13px;
      font-weight: 600;
      flex-wrap: wrap;
      justify-content: flex-end;
    }
    nav a {
      padding-bottom: 2px;
      border-bottom: 2px solid transparent;
      transition: color .15s, border-color .15s;
    }
    nav a:hover { color: var(--navy); border-bottom-color: var(--navy); }

    /* ハンバーガー */
    .hamburger {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 36px;
      height: 36px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      flex-shrink: 0;
    }
    .hamburger span {
      display: block;
      width: 100%;
      height: 2px;
      background: var(--navy);
      border-radius: 2px;
      transition: transform .25s, opacity .25s;
    }
    .hamburger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
    .hamburger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    .mobile-nav {
      display: none;
      flex-direction: column;
      background: #fff;
      border-bottom: 1px solid var(--border);
      padding: 8px 0 16px;
    }
    .mobile-nav a {
      display: block;
      padding: 13px 24px;
      font-size: 15px;
      font-weight: 600;
      color: #374151;
      border-bottom: 1px solid #f3f6fa;
    }
    .mobile-nav.open { display: flex; }

    /* ===== ティッカー帯 ===== */
    .ticker {
      background: var(--navy);
      color: #fff;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .ticker-inner {
      max-width: 1160px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      align-items: stretch;
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
    }
    .t-date {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 10px 20px 10px 0;
      border-right: 1px solid rgba(255,255,255,.16);
      flex-shrink: 0;
    }
    .t-date .d { font-size: 14px; font-weight: 700; letter-spacing: .03em; }
    .t-date .s { font-size: 10px; color: #93b2d8; letter-spacing: .1em; }
    .t-item {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 10px 20px;
      border-right: 1px solid rgba(255,255,255,.10);
      flex-shrink: 0;
    }
    .t-item .l { font-size: 10px; color: #93b2d8; letter-spacing: .06em; }
    .t-item .v { font-size: 14.5px; font-weight: 700; }

    /* ===== 本体 ===== */
    .shell {
      max-width: 1160px;
      margin: 0 auto;
      padding: 36px 24px 56px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) 300px;
      gap: 40px;
      align-items: start;
    }
    /* Bear Blog由来の main{margin:auto;padding:3em} を無効化（左カラムが縦センタリングされ上部に空白ができる不具合の解消） */
    .shell > main { margin: 0; padding: 0; min-width: 0; }

    /* リード記事 */
    .lead-eyebrow {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 14px;
      flex-wrap: wrap;
    }
    .lead-tag {
      background: var(--navy);
      color: #fff;
      font-size: 11.5px;
      font-weight: 700;
      padding: 2px 11px;
      letter-spacing: .06em;
      border-radius: 3px;
    }
    .lead-date { font-size: 12.5px; color: var(--muted); letter-spacing: .03em; }
    .lead-title {
      font-family: var(--serif);
      font-size: clamp(23px, 3.2vw, 30px);
      font-weight: 700;
      line-height: 1.5;
      letter-spacing: .01em;
      color: var(--text);
      margin: 0 0 14px;
      text-wrap: balance;
    }
    .lead-title a:hover { color: var(--navy-2); }
    .lead-summary {
      font-size: 14px;
      color: var(--muted);
      line-height: 1.9;
      margin: 0 0 20px;
      max-width: 40em;
    }
    .statline {
      display: flex;
      align-items: baseline;
      gap: 16px;
      flex-wrap: wrap;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 14px 2px;
      margin-bottom: 22px;
      font-variant-numeric: tabular-nums;
    }
    .statline .k { font-size: 12px; color: var(--muted); }
    .statline .v { font-size: 27px; font-weight: 700; color: var(--text); letter-spacing: .01em; line-height: 1.2; }
    .statline .s { font-size: 12px; color: var(--muted); }
    .lead-btns { display: flex; gap: 12px; flex-wrap: wrap; }
    .btn-p {
      display: inline-flex;
      align-items: center;
      background: var(--navy);
      color: #fff;
      font-size: 13px;
      font-weight: 700;
      padding: 10px 22px;
      border-radius: 4px;
      transition: background .15s;
    }
    .btn-p:hover { background: #1d3a63; }
    .btn-g {
      display: inline-flex;
      align-items: center;
      color: var(--navy);
      font-size: 13px;
      font-weight: 700;
      padding: 10px 18px;
      border: 1px solid var(--navy);
      border-radius: 4px;
      transition: background .15s;
    }
    .btn-g:hover { background: var(--blue); }

    /* ノートの索引 */
    .index-sec { margin-top: 44px; }
    .index-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      border-bottom: 2px solid var(--navy);
      padding-bottom: 8px;
    }
    .index-head h2 {
      font-family: var(--serif);
      font-size: 18px;
      font-weight: 700;
      letter-spacing: .04em;
      margin: 0;
      color: var(--text);
    }
    .index-head a { font-size: 12px; color: var(--muted); }
    .index-head a:hover { color: var(--navy); }
    .idx-row {
      display: grid;
      grid-template-columns: 72px 92px 1fr;
      gap: 14px;
      align-items: baseline;
      padding: 14px 2px;
      border-bottom: 1px solid var(--border);
      transition: background .15s;
    }
    .idx-row:hover { background: #f0f5fa; }
    .idx-d { font-size: 12.5px; color: var(--muted); font-variant-numeric: tabular-nums; letter-spacing: .02em; }
    .idx-b {
      font-size: 11px;
      font-weight: 700;
      padding: 1px 8px;
      border-radius: 3px;
      justify-self: start;
      white-space: nowrap;
    }
    .b-nk { color: var(--navy); background: #e8eef6; }
    .b-dp { color: #5b3a0e; background: #f6efe0; }
    .b-wk { color: #0d5c48; background: #e2f2ec; }
    .b-mm { color: #4c1d95; background: #efeafb; }
    .b-gl { color: #334155; background: #eceff3; }
    .idx-t { font-size: 13.5px; font-weight: 600; color: var(--text); line-height: 1.65; }
    .idx-more {
      display: block;
      text-align: right;
      font-size: 12.5px;
      color: var(--muted);
      padding: 12px 2px 0;
    }
    .idx-more:hover { color: var(--navy); }

    /* 用語解説バナー */
    .glossary-banner {
      background: var(--navy);
      border-radius: 10px;
      padding: 28px 30px;
      margin: 36px 0 0;
      display: flex;
      gap: 32px;
      align-items: center;
    }
    .glossary-banner-left { flex: 1; min-width: 0; }
    .glossary-eyebrow {
      display: inline-block;
      font-size: 10.5px;
      font-weight: 700;
      letter-spacing: .12em;
      color: #93b2d8;
      margin-bottom: 10px;
    }
    .glossary-banner-title {
      font-family: var(--serif);
      font-size: 20px;
      font-weight: 700;
      color: #fff;
      margin: 0 0 8px;
      line-height: 1.4;
    }
    .glossary-banner-sub {
      font-size: 13px;
      color: #9ec4e8;
      line-height: 1.75;
      margin: 0 0 18px;
    }
    .glossary-banner-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: #fff;
      color: var(--navy);
      font-weight: 700;
      font-size: 13px;
      border-radius: 4px;
      padding: 9px 22px;
      transition: opacity .15s;
    }
    .glossary-banner-btn:hover { opacity: .88; }
    .glossary-banner-right {
      display: flex;
      flex-direction: column;
      gap: 8px;
      flex-shrink: 0;
      width: 230px;
    }
    .glossary-term-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .06em;
      color: rgba(255,255,255,.45);
      margin-bottom: 2px;
    }
    .glossary-term-item {
      display: flex;
      align-items: center;
      gap: 8px;
      color: #dce7f6;
      font-size: 13.5px;
      font-weight: 600;
      padding: 9px 14px;
      background: rgba(255,255,255,.07);
      border-radius: 6px;
      border: 1px solid rgba(255,255,255,.1);
      transition: background .15s;
    }
    .glossary-term-item:hover { background: rgba(255,255,255,.14); }
    .glossary-term-item::before { content: '→'; font-size: 12px; color: #7fa8d8; flex-shrink: 0; }
    .glossary-term-more { font-size: 12px; color: #93b2d8; padding: 4px 14px; font-weight: 600; }

    /* 立ち位置 */
    .note-box {
      background: var(--white);
      border: 1px solid var(--border);
      border-left: 3px solid var(--navy);
      border-radius: 0 8px 8px 0;
      padding: 18px 20px;
      margin-top: 24px;
    }
    .note-box h3 {
      margin: 0 0 6px;
      color: var(--navy);
      font-family: var(--serif);
      font-size: 15px;
    }
    .note-box p { margin: 0; font-size: 13.5px; color: var(--muted); }

    /* ===== 右レール ===== */
    aside { display: grid; gap: 20px; align-content: start; }
    .side-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 18px 18px 14px;
    }
    .side-card h3 {
      margin: 0 0 4px;
      color: var(--text);
      font-family: var(--serif);
      font-size: 14px;
      font-weight: 700;
      letter-spacing: .05em;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--border);
    }
    .mkt { display: grid; }
    .mkt .r {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 10px;
      padding: 8px 0;
      border-bottom: 1px dashed var(--border);
      font-variant-numeric: tabular-nums;
    }
    .mkt .r:last-child { border-bottom: none; }
    .mkt .l { font-size: 12px; color: var(--muted); }
    .mkt .v { font-size: 13.5px; font-weight: 700; color: var(--navy); }
    .mkt-note { font-size: 10.5px; color: var(--muted); margin: 8px 0 0; line-height: 1.6; }

    .cp-card b { display: block; color: var(--navy); font-size: 12.5px; margin: 10px 0 2px; }
    .cp-card span { color: var(--muted); font-size: 12px; line-height: 1.7; display: block; }

    .pills { display: flex; flex-wrap: wrap; gap: 7px; padding-top: 10px; }
    .pill {
      font-size: 12px;
      color: var(--navy);
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 3px 12px;
      background: #f7f9fb;
      transition: background .15s;
    }
    .pill:hover { background: var(--blue); }
    .rail-link { font-size: 12px; color: var(--muted); padding-top: 10px; display: block; }
    .rail-link:hover { color: var(--navy); }

    .category-list { display: grid; gap: 7px; padding-top: 10px; }
    .category-list a {
      display: flex;
      justify-content: space-between;
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 8px 12px;
      background: #fbfdff;
      font-size: 13px;
      font-weight: 600;
      color: #374151;
      transition: background .15s;
    }
    .category-list a:hover { background: var(--blue-2); }
    .category-list .cnt { color: var(--muted); font-variant-numeric: tabular-nums; }

    .theme-row { display: flex; flex-wrap: wrap; gap: 7px; padding-top: 10px; }
    .theme-badge {
      background: var(--blue-2);
      color: var(--navy-2);
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 3px 11px;
      font-size: 11.5px;
      font-weight: 600;
    }
    .profile { display: flex; gap: 12px; align-items: center; padding-top: 10px; }
    .avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--blue);
      display: grid;
      place-items: center;
      font-family: var(--serif);
      font-weight: 700;
      color: var(--navy);
      flex-shrink: 0;
    }
    .profile p { margin: 0; font-size: 12.5px; color: var(--muted); line-height: 1.7; }
    .side-note { font-size: 12px; color: var(--muted); margin: 0; padding-top: 10px; line-height: 1.7; }

    /* フッター */
    .footer {
      background: var(--navy);
      color: #dce7f6;
      padding: 30px 24px;
    }
    .footer-inner {
      max-width: 1160px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      gap: 18px;
      flex-wrap: wrap;
      font-size: 13px;
    }
    .footer-inner a { color: #9ec4e8; }

    /* ===== レスポンシブ ===== */
    @media (max-width: 980px) {
      /* モバイル: main/aside を display:contents で解体し、直下ブロックを order で並べ替える。
         デスクトップのグリッドには一切影響しない。 */
      .shell {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        gap: 28px;
      }
      .shell > main,
      .shell > aside { display: contents; }
      .shell > main > *,
      .shell > aside > * { margin: 0; }

      /* 表示順: ヒーロー → 朝のチェックポイント → 索引 → 用語バナー → 残りサイドバー → 立ち位置 */
      .shell .lead-sec        { order: 1; }
      .shell aside .cp-card   { order: 2; }
      .shell .index-sec       { order: 3; }
      .shell .glossary-banner { order: 4; }
      .shell aside > *        { order: 5; }
      .shell .note-box        { order: 6; }

      /* 相場サマリーはティッカー帯と数値が重複するためモバイルでは隠す */
      .shell aside .summary   { display: none; }
    }
    @media (max-width: 860px) {
      nav { display: none; }
      .hamburger { display: flex; }
      .shell { padding: 24px 16px 44px; }
      .ticker-inner { padding: 0 16px; }
      .header-inner { padding: 12px 16px; }
      .glossary-banner { flex-direction: column; gap: 20px; padding: 24px 20px; }
      .glossary-banner-right { width: 100%; }
      .statline .v { font-size: 23px; }
      .idx-row { grid-template-columns: 64px 1fr; }
      .idx-b { display: none; }
    }
  </style>
</head>
<body>
  <header>
    <div class="header-inner">
      <a class="brand" href="/">
        <span class="brand-icon">株</span>
        <span>今日の日本株ノート</span>
      </a>
      <nav>
        <a href="/blog">今日の相場</a>
        <a href="/blog/category/deep">深掘りノート</a>
        <a href="/blog/category/nikkei">日経ノート</a>
        <a href="/blog/category/memo">投資メモ</a>
        <a href="/blog/category/glossary/">用語解説</a>
        <a href="/about">このサイトについて</a>
      </nav>
      <button class="hamburger" aria-label="メニューを開く" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="mobile-nav" id="mobile-nav">
      <a href="/blog">今日の相場</a>
      <a href="/blog/category/deep">深掘りノート</a>
      <a href="/blog/category/nikkei">日経ノート</a>
      <a href="/blog/category/memo">投資メモ</a>
      <a href="/blog/category/glossary/">用語解説</a>
      <a href="/about">このサイトについて</a>
    </div>
  </header>

  {md && (
    <div class="ticker" aria-label="主要指標（最新記事時点）">
      <div class="ticker-inner">
        <div class="t-date">
          <span class="d">{jpDate(md.nikkeiDate)}</span>
          <span class="s">大引け時点</span>
        </div>
        {md.nikkei && (
          <div class="t-item">
            <span class="l">日経平均</span>
            <span class="v">{fmtNum(md.nikkei)}</span>
          </div>
        )}
        {md.topix && (
          <div class="t-item">
            <span class="l">TOPIX</span>
            <span class="v">{fmtNum(md.topix)}</span>
          </div>
        )}
        {md.usd && (
          <div class="t-item">
            <span class="l">ドル円（15時30分）</span>
            <span class="v">{fmtNum(md.usd)}</span>
          </div>
        )}
        {md.dow && (
          <div class="t-item">
            <span class="l">NYダウ（{shortMD(md.dowDate)}終値）</span>
            <span class="v">{fmtNum(md.dow)}</span>
          </div>
        )}
        {md.nasdaq && (
          <div class="t-item">
            <span class="l">NASDAQ（{shortMD(md.nasdaqDate)}終値）</span>
            <span class="v">{fmtNum(md.nasdaq)}</span>
          </div>
        )}
      </div>
    </div>
  )}

  <div class="shell">
    <main>
      {latestPost && (
        <section class="lead-sec" aria-label="今日のノート">
          <div class="lead-eyebrow">
            {leadBadge && <span class="lead-tag">{leadBadge.label}</span>}
            <span class="lead-date">{leadDate}</span>
          </div>
          <h1 class="lead-title">
            <a href={`/blog/${latestPost.id}/`}>{stripTitle(latestPost.data.title, latestPost.data.category)}</a>
          </h1>
          <p class="lead-summary">{latestPost.data.description}</p>
          {md?.nikkei && (
            <div class="statline">
              <span class="k">日経平均 終値</span>
              <span class="v">{fmtNum(md.nikkei)}</span>
              <span class="s">{fmtD(md.nikkeiDate)} 大引け</span>
            </div>
          )}
          <div class="lead-btns">
            <a class="btn-p" href={`/blog/${latestPost.id}/`}>このノートを読む</a>
            {leadCompanionDeep ? (
              <a class="btn-g" href={`/blog/${leadCompanionDeep.id}/`}>深掘り版（詳しく）</a>
            ) : (
              <a class="btn-g" href="/blog">記事一覧を見る</a>
            )}
          </div>
        </section>
      )}

      <section class="index-sec" id="latest" aria-label="最近のノート">
        <div class="index-head">
          <h2>ノートの索引</h2>
          <a href="/blog">すべての記事 →</a>
        </div>
        {recentPosts.map(post => {
          const b = catBadge[post.data.category ?? ''] ?? { label: '記事', cls: 'b-gl' };
          return (
            <a class="idx-row" href={`/blog/${post.id}/`}>
              <span class="idx-d">{rowDate(post.data.pubDate)}</span>
              <span class={`idx-b ${b.cls}`}>{b.label}</span>
              <span class="idx-t">{stripTitle(post.data.title, post.data.category)}</span>
            </a>
          );
        })}
        <a class="idx-more" href="/blog">記事一覧・カレンダーで探す →</a>
      </section>

      <!-- 用語解説バナー -->
      <div class="glossary-banner">
        <div class="glossary-banner-left">
          <span class="glossary-eyebrow">GLOSSARY</span>
          <h2 class="glossary-banner-title">投資用語を調べる</h2>
          <p class="glossary-banner-sub">
            寄与度・値がさ株・TOPIXなど、相場ノートに頻出する用語を<br>
            図解・実例つきでわかりやすく解説します。
          </p>
          <a class="glossary-banner-btn" href="/blog/category/glossary/">
            用語解説 {glossaryCount}語を見る →
          </a>
        </div>
        {latestGlossary.length > 0 && (
          <div class="glossary-banner-right">
            <div class="glossary-term-label">最新の解説</div>
            {latestGlossary.map(p => (
              <a class="glossary-term-item" href={`/blog/${p.id}/`}>
                {p.data.title.replace(/とは.*/, '').replace(/？.*/, '')}
              </a>
            ))}
            <a class="glossary-term-more" href="/blog/category/glossary/">全用語一覧を見る →</a>
          </div>
        )}
      </div>

      <div class="note-box" id="concept">
        <h3>このサイトの立ち位置</h3>
        <p>短期売買をあおるサイトではなく、相場の流れを毎日整理し、翌営業日の見方を準備するための"相場ノート"です。</p>
      </div>
    </main>

    <aside>
      {md && (
        <div class="side-card summary">
          <h3>相場サマリー</h3>
          <div class="mkt">
            {md.nikkei && <div class="r"><span class="l">日経平均</span><span class="v">{fmtNum(md.nikkei)}</span></div>}
            {md.topix && <div class="r"><span class="l">TOPIX</span><span class="v">{fmtNum(md.topix)}</span></div>}
            {md.usd && <div class="r"><span class="l">ドル円</span><span class="v">{fmtNum(md.usd)}</span></div>}
            {md.dow && <div class="r"><span class="l">NYダウ</span><span class="v">{fmtNum(md.dow)}</span></div>}
            {md.nasdaq && <div class="r"><span class="l">NASDAQ</span><span class="v">{fmtNum(md.nasdaq)}</span></div>}
          </div>
          <p class="mkt-note">{fmtD(md.nikkeiDate)} 大引け／米国は{fmtD(md.dowDate)}終値／ドル円は15時30分時点</p>
        </div>
      )}

      <div class="side-card cp-card">
        <h3>朝のチェックポイント</h3>
        {checkPoints.map((cp, i) => (
          <div><b>{i + 1}. {cp.title}</b><span>{cp.text}</span></div>
        ))}
      </div>

      <div class="side-card">
        <h3>用語をひく</h3>
        <div class="pills">
          {latestGlossary.map(p => (
            <a class="pill" href={`/blog/${p.id}/`}>
              {p.data.title.replace(/とは.*/, '').replace(/？.*/, '')}
            </a>
          ))}
        </div>
        <a class="rail-link" href="/blog/category/glossary/">用語解説 全{glossaryCount}語 →</a>
      </div>

      <CalendarWidget />

      <div class="side-card">
        <h3>カテゴリー</h3>
        <div class="category-list">
          {Object.entries(categoryCounts).map(([, info]) => (
            <a href={info.href}>
              <span>{info.label}</span>
              <span class="cnt">{info.count}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="side-card">
        <h3>今週の注目テーマ</h3>
        <div class="theme-row">
          {weeklyThemes.map(theme => (
            <span class="theme-badge">{theme}</span>
          ))}
        </div>
      </div>

      <div class="side-card">
        <h3>運営者メモ</h3>
        <div class="profile">
          <div class="avatar">株</div>
          <p>日本株市場の動きを、日々の投資判断の前提整理として読みやすくまとめます。</p>
        </div>
      </div>

      <div class="side-card">
        <h3>免責事項</h3>
        <p class="side-note">当サイトは情報提供を目的としており、特定銘柄の売買を推奨するものではありません。投資判断はご自身の責任でお願いいたします。</p>
      </div>
    </aside>
  </div>

  <footer class="footer">
    <div class="footer-inner">
      <div>© 今日の日本株ノート</div>
      <div>
        <a href="/about">このサイトについて</a>｜
        <a href="/privacy">プライバシーポリシー</a>｜
        <a href="/contact">お問い合わせ</a>
      </div>
    </div>
  </footer>

  <script>
    const btn = document.querySelector('.hamburger');
    const mobileNav = document.querySelector('.mobile-nav');
    btn?.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isOpen));
      btn.setAttribute('aria-label', isOpen ? 'メニューを開く' : 'メニューを閉じる');
      mobileNav?.classList.toggle('open', !isOpen);
    });
  </script>
</body>
</html>
