---
import BaseHead from '../../../components/BaseHead.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import { SITE_TITLE } from '../../../consts';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const categories = [...new Set(posts.map((p) => p.data.category).filter(Boolean))]
    .filter((c) => c !== 'glossary');
  return categories.map((category) => ({ params: { category } }));
}

const { category } = Astro.params;

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((p) => p.data.category === category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryLabel: Record<string, string> = {
  nikkei: '日経ノート',
  deep: '深掘りノート',
  memo: '投資メモ',
  glossary: '用語解説',
  weekly: '週次振り返り',
  monthly: '月次まとめ',
  guide: '投資ガイド',
};

const label = category ? (categoryLabel[category] ?? category) : '記事';
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={label} description={`${label}の記事一覧です。`} />
    <style>
      :root {
        --navy: #10233f;
        --navy-2: #2c4a74;
        --blue: #eaf2fb;
        --blue-2: #f5f8fc;
        --text: #1c2534;
        --muted: #5d6b80;
        --border: #e2e7ee;
        --white: #ffffff;
        --shadow: 0 1px 2px rgba(16, 35, 63, .05);
        --radius: 10px;
        --serif: "Noto Serif JP", "Yu Mincho", "Hiragino Mincho ProN", serif;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: "Hiragino Kaku Gothic ProN", "Hiragino Sans", "Yu Gothic Medium", "Yu Gothic", "Noto Sans JP", "Meiryo", sans-serif;
        color: var(--text);
        background: #f7f9fb;
        line-height: 1.85;
      }

      a { color: inherit; text-decoration: none; }

      /* ヘッダーはSiteHeaderで管理 */

      .breadcrumb {
        max-width: 1200px;
        margin: 0 auto;
        padding: 14px 20px 0;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: var(--muted);
      }

      .breadcrumb a { color: var(--navy); }

      .page-inner {
        max-width: 1200px;
        margin: 28px auto 60px;
        padding: 0 20px;
      }

      .page-title {
        font-family: var(--serif);
        font-size: 22px;
        font-weight: 700;
        color: var(--text);
        padding-bottom: 10px;
        border-bottom: 2px solid var(--navy);
        margin-bottom: 20px;
      }

      .category-tabs {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 28px;
      }

      .category-tab {
        display: inline-block;
        padding: 6px 16px;
        border-radius: 999px;
        border: 1px solid var(--border);
        font-size: 13px;
        font-weight: 600;
        color: var(--muted);
        background: var(--white);
        transition: all .15s;
      }

      .category-tab:hover,
      .category-tab.active {
        background: var(--navy);
        color: #fff;
        border-color: var(--navy);
      }

      .post-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0;
      }

      .post-card {
        background: transparent;
        border-bottom: 1px solid var(--border);
        padding: 16px 4px;
        transition: background .15s;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      .post-card:hover {
        background: #f0f5fa;
      }

      .post-meta {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .badge {
        background: #e8eef6;
        color: var(--navy);
        border-radius: 3px;
        padding: 1px 9px;
        font-size: 11px;
        font-weight: 700;
      }

      .post-date {
        font-size: 12px;
        color: var(--muted);
        font-variant-numeric: tabular-nums;
      }

      .post-title {
        font-size: 14.5px;
        font-weight: 600;
        color: var(--text);
        line-height: 1.65;
      }

      .post-description {
        font-size: 12.5px;
        color: var(--muted);
        line-height: 1.7;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .empty {
        grid-column: 1 / -1;
        text-align: center;
        padding: 60px 20px;
        color: var(--muted);
        font-size: 15px;
      }

      footer {
        background: var(--navy);
        color: #dce7f6;
        padding: 28px 20px;
      }

      .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
        font-size: 13px;
      }

      .footer-inner a { color: #9ec4e8; }

      @media (max-width: 860px) {
        nav { display: none; }
        .post-grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>

    <SiteHeader currentCategory={category} />

    <div class="breadcrumb">
      <a href="/">ホーム</a>
      <span>›</span>
      <a href="/blog">記事一覧</a>
      <span>›</span>
      <span>{label}</span>
    </div>

    <div class="page-inner">
      <h1 class="page-title">{label}</h1>

      <div class="category-tabs">
        <a class="category-tab" href="/blog">すべて</a>
        <a class="category-tab" href="/blog/category/nikkei" class:list={[{ active: category === 'nikkei' }]}>日経ノート</a>
        <a class="category-tab" href="/blog/category/deep" class:list={[{ active: category === 'deep' }]}>深掘りノート</a>
        <a class="category-tab" href="/blog/category/memo" class:list={[{ active: category === 'memo' }]}>投資メモ</a>
        <a class="category-tab" href="/blog/category/glossary" class:list={[{ active: category === 'glossary' }]}>用語解説</a>
      </div>

      <div class="post-grid">
        {posts.length === 0 && (
          <p class="empty">現在この カテゴリーの記事はありません。</p>
        )}
        {posts.map((post) => (
          <a class="post-card" href={`/blog/${post.id}/`}>
            <div class="post-meta">
              <span class="badge">{label}</span>
              <span class="post-date">
                {post.data.pubDate.getFullYear()}年{post.data.pubDate.getMonth() + 1}月{post.data.pubDate.getDate()}日
              </span>
            </div>
            <p class="post-title">{post.data.title}</p>
            {post.data.description && (
              <p class="post-description">{post.data.description}</p>
            )}
          </a>
        ))}
      </div>
    </div>

    <SiteFooter />

  </body>
</html>
