---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import { SITE_TITLE } from '../../../consts';
import '../../../styles/glossary.css';

const allPosts = await getCollection('blog');
const glossaryPosts = allPosts
  .filter((p) => p.data.category === 'glossary')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const totalCount = glossaryPosts.length;

// セクション分類マッピング
const sectionMap: Record<string, string[]> = {
  '指数・市場': ['日経平均', '指数', '東証', 'TOPIX', 'MSCI', 'JPX'],
  '需給・板':   ['需給', '空売り', '先物', '信用取引', '板'],
  '為替・金利': ['為替', '金利', 'ドル円', 'リスク', '日銀'],
  'テクニカル': ['チャート', 'テクニカル', 'トレンド', 'RSI', 'MACD'],
  '決算・指標': ['決算', 'PER', 'PBR', 'EPS', 'ROE'],
  '制度・取引': ['NISA', '単元未満株', '指値', '制度'],
  'マクロ経済': ['マクロ', 'インフレ', '景気', 'GDP'],
};

const sectionIcons: Record<string, string> = {
  '指数・市場': '📊',
  '需給・板':   '📋',
  '為替・金利': '💱',
  'テクニカル': '📈',
  '決算・指標': '📑',
  '制度・取引': '🏛',
  'マクロ経済': '🌐',
};

function classifyPost(tags: string[] | undefined): string {
  if (!tags) return '指数・市場';
  for (const [section, keywords] of Object.entries(sectionMap)) {
    if (tags.some((tag) => keywords.includes(tag))) return section;
  }
  return '指数・市場';
}

// セクションごとに記事を分類
const sections = Object.keys(sectionMap).map((name) => ({
  name,
  icon: sectionIcons[name] ?? '📌',
  posts: glossaryPosts.filter((p) => classifyPost(p.data.tags) === name),
}));

// 五十音・アルファベット判定
const kanaRows: { label: string; chars: string }[] = [
  { label: 'あ', chars: 'あいうえお' },
  { label: 'か', chars: 'かきくけこ' },
  { label: 'さ', chars: 'さしすせそ' },
  { label: 'た', chars: 'たちつてと' },
  { label: 'な', chars: 'なにぬねの' },
  { label: 'は', chars: 'はひふへほ' },
  { label: 'ま', chars: 'まみむめも' },
  { label: 'や', chars: 'やゆよ' },
  { label: 'ら', chars: 'らりるれろ' },
  { label: 'わ', chars: 'わをん' },
];
const alphaGroups: { label: string; chars: string }[] = [
  { label: 'A–F', chars: 'abcdefABCDEF' },
  { label: 'G–L', chars: 'ghijklGHIJKL' },
  { label: 'M–R', chars: 'mnopqrMNOPQR' },
  { label: 'S–Z', chars: 'stuvwxyzSTUVWXYZ' },
];

const firstChars = new Set(glossaryPosts.map((p) => p.data.title.charAt(0)));

function rowHasItems(chars: string): boolean {
  for (const ch of firstChars) {
    if (chars.includes(ch)) return true;
  }
  return false;
}

// まず読みたい3選（固定）
const picks = [
  { slug: '20260601-glossary-kiyodo', name: '寄与度',     desc: '日経平均の値動きを読む上で最も重要な概念。1銘柄が指数に与える影響を理解しよう。' },
  { slug: '',                          name: 'TOPIXとは',  desc: '東証全体を反映する時価総額加重型指数。日経平均との比較で市場の歪みが見える。' },
  { slug: '',                          name: 'リスクオフ', desc: '相場が不安定になるときに必ず登場する言葉。円高・金への資金逃避のメカニズムを解説。' },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title={`用語解説一覧 | ${SITE_TITLE}`}
      description="日経平均・TOPIX・需給・テクニカルなど、投資の現場で使われる用語を分かりやすく解説します。"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@700;800&display=swap" rel="stylesheet">
  </head>

  <body class="glossary-page">
    <SiteHeader currentCategory="glossary" />

    <!-- ヒーロー -->
    <section class="gi-hero">
      <span class="gi-hero-eyebrow">GLOSSARY</span>
      <h1 class="gi-hero-title">
        相場ノートをもっと深く読むための<br>投資用語解説
      </h1>
      <p class="gi-hero-sub">
        日経平均・需給・テクニカルなど、毎日の相場ノートに登場する用語を<br class="pc-br">
        図解・実例つきで丁寧に解説します。
      </p>
      <div class="gi-hero-badges">
        <span class="gi-hero-badge">解説済み用語 <span>{totalCount}</span>語</span>
        <span class="gi-hero-badge">カテゴリー <span>8</span>分類</span>
        <span class="gi-hero-badge">毎週更新中</span>
      </div>
    </section>

    <!-- 検索バー -->
    <div class="gi-search-wrap">
      <div class="gi-search-box">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          class="gi-search-input"
          type="search"
          id="gi-search"
          placeholder="用語を検索…（例：寄与度、TOPIX）"
          autocomplete="off"
        >
        <span class="gi-search-count" id="gi-count">{totalCount}語</span>
      </div>
    </div>

    <div class="gi-main">

      <!-- まず読みたい3選 -->
      <div class="gi-reco">
        <div class="gi-reco-title">▶ まず読みたい3選</div>
        <div class="gi-reco-grid">
          {picks.map((pick, i) => (
            <a class="gi-reco-card" href={pick.slug ? `/blog/${pick.slug}/` : '/blog/category/glossary/'}>
              <div class="gi-reco-num">0{i + 1}</div>
              <div class="gi-reco-name">{pick.name}</div>
              <div class="gi-reco-desc">{pick.desc}</div>
            </a>
          ))}
        </div>
      </div>

      <!-- カテゴリータブ -->
      <div class="gi-tabs" id="gi-tabs">
        <button class="gi-tab active" data-section="all">
          すべて
          <span class="gi-tab-count">{totalCount}</span>
        </button>
        {sections.map((sec) => (
          <button class="gi-tab" data-section={sec.name}>
            {sec.name}
            <span class="gi-tab-count">{sec.posts.length}</span>
          </button>
        ))}
      </div>

      <!-- no results -->
      <div class="gi-no-results" id="gi-no-results">
        一致する用語が見つかりませんでした。別のキーワードをお試しください。
      </div>

      <!-- セクション別カードグリッド -->
      {sections.map((sec) => (
        <section class="gi-section" id={`sec-${sec.name}`} data-section={sec.name}>
          <div class="gi-section-header">
            <div class="gi-section-icon">{sec.icon}</div>
            <div class="gi-section-title">{sec.name}</div>
            <div class="gi-section-count">{sec.posts.length}語</div>
          </div>

          {sec.posts.length === 0 ? (
            <p class="gi-empty">この分類の用語解説は準備中です。</p>
          ) : (
            <div class="gi-card-grid">
              {sec.posts.map((post) => {
                const isNew     = post.data.tags?.includes('new')     ?? false;
                const isPopular = post.data.tags?.includes('popular') ?? false;
                const desc      = (post.data.description ?? '').slice(0, 60);
                const displayTags = (post.data.tags ?? []).filter((t) => !['new', 'popular'].includes(t)).slice(0, 2);
                return (
                  <a
                    class="gi-card"
                    href={`/blog/${post.id}/`}
                    data-title={post.data.title}
                    data-desc={post.data.description ?? ''}
                    data-tags={(post.data.tags ?? []).join(' ')}
                    data-first={post.data.title.charAt(0)}
                  >
                    <div class="gi-card-top">
                      <div class="gi-card-name">{post.data.title.replace(/とは.*/, '').replace(/？.*/, '')}</div>
                      {isNew     && <span class="gi-card-badge new">NEW</span>}
                      {isPopular && <span class="gi-card-badge popular">人気</span>}
                    </div>
                    <p class="gi-card-desc">{desc}{desc.length >= 60 ? '…' : ''}</p>
                    {displayTags.length > 0 && (
                      <div class="gi-card-tags">
                        {displayTags.map((t) => <span class="gi-card-tag">#{t}</span>)}
                      </div>
                    )}
                    <div class="gi-demand-bar-wrap">
                      <span class="gi-demand-label">需要</span>
                      <div class="gi-demand-track">
                        <div class="gi-demand-fill" style="width:72%"></div>
                      </div>
                    </div>
                    <span class="gi-card-arrow">→</span>
                  </a>
                );
              })}
            </div>
          )}
        </section>
      ))}

      <!-- 五十音・アルファベット索引 -->
      <div class="gi-index-section">
        <h2 class="gi-index-title">五十音・アルファベット索引</h2>

        <div class="gi-index-group">
          <div class="gi-index-group-label">五十音</div>
          <div class="gi-index-buttons" id="gi-kana-btns">
            {kanaRows.map((row) => {
              const has = rowHasItems(row.chars);
              return (
                <button
                  class={`gi-index-btn${has ? ' has-items' : ' empty'}`}
                  data-chars={row.chars}
                  disabled={!has}
                >
                  {row.label}
                </button>
              );
            })}
          </div>
        </div>

        <div class="gi-index-group">
          <div class="gi-index-group-label">アルファベット</div>
          <div class="gi-index-buttons" id="gi-alpha-btns">
            {alphaGroups.map((grp) => {
              const has = rowHasItems(grp.chars);
              return (
                <button
                  class={`gi-index-btn${has ? ' has-items' : ' empty'}`}
                  data-chars={grp.chars}
                  disabled={!has}
                >
                  {grp.label}
                </button>
              );
            })}
          </div>
        </div>
      </div>

    </div><!-- /gi-main -->

    <footer class="g-footer">
      <div class="g-footer-inner">
        <div>© 今日の日本株ノート</div>
        <div>
          <a href="/about">このサイトについて</a>｜
          <a href="/privacy">プライバシーポリシー</a>｜
          <a href="/contact">お問い合わせ</a>
        </div>
      </div>
    </footer>

    <script>
      (() => {
        const searchInput  = document.getElementById('gi-search')  as HTMLInputElement | null;
        const countEl      = document.getElementById('gi-count');
        const noResults    = document.getElementById('gi-no-results');
        const tabsEl       = document.getElementById('gi-tabs');
        const allCards     = Array.from(document.querySelectorAll<HTMLElement>('.gi-card'));
        const allSections  = Array.from(document.querySelectorAll<HTMLElement>('.gi-section'));

        let activeSection  = 'all';
        let activeChars    = '';

        function updateDisplay() {
          const query = (searchInput?.value ?? '').trim().toLowerCase();
          let visibleCount = 0;

          allCards.forEach((card) => {
            const title  = (card.dataset.title  ?? '').toLowerCase();
            const desc   = (card.dataset.desc   ?? '').toLowerCase();
            const tags   = (card.dataset.tags   ?? '').toLowerCase();
            const first  = card.dataset.first   ?? '';
            const section = card.closest<HTMLElement>('.gi-section')?.dataset.section ?? '';

            const matchSearch  = !query    || title.includes(query) || desc.includes(query) || tags.includes(query);
            const matchSection = activeSection === 'all' || section === activeSection;
            const matchChars   = !activeChars || activeChars.includes(first);

            const visible = matchSearch && matchSection && matchChars;
            card.style.display = visible ? '' : 'none';
            if (visible) visibleCount++;
          });

          // セクションが全非表示なら is-empty クラス
          allSections.forEach((sec) => {
            const secName = sec.dataset.section ?? '';
            const sectionMatch = activeSection === 'all' || secName === activeSection;
            if (!sectionMatch) {
              sec.style.display = 'none';
            } else {
              sec.style.display = '';
              const visible = Array.from(sec.querySelectorAll<HTMLElement>('.gi-card'))
                .some((c) => c.style.display !== 'none');
              sec.classList.toggle('is-empty', !visible);
            }
          });

          if (countEl) countEl.textContent = `${visibleCount}語`;
          if (noResults) noResults.classList.toggle('visible', visibleCount === 0);
        }

        // 検索
        searchInput?.addEventListener('input', updateDisplay);

        // タブ
        tabsEl?.addEventListener('click', (e) => {
          const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.gi-tab');
          if (!btn) return;
          tabsEl.querySelectorAll('.gi-tab').forEach((t) => t.classList.remove('active'));
          btn.classList.add('active');
          activeSection = btn.dataset.section ?? 'all';

          // セクションへスクロール
          if (activeSection !== 'all') {
            const target = document.getElementById(`sec-${activeSection}`);
            if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }

          updateDisplay();
        });

        // 五十音・アルファベット索引
        document.querySelectorAll<HTMLButtonElement>('.gi-index-btn.has-items').forEach((btn) => {
          btn.addEventListener('click', () => {
            if (btn.classList.contains('active')) {
              btn.classList.remove('active');
              activeChars = '';
            } else {
              document.querySelectorAll('.gi-index-btn').forEach((b) => b.classList.remove('active'));
              btn.classList.add('active');
              activeChars = btn.dataset.chars ?? '';
            }
            updateDisplay();
          });
        });
      })();
    </script>

    <style>
      .pc-br { display: none; }
      @media (min-width: 640px) { .pc-br { display: block; } }
    </style>

  </body>
</html>
