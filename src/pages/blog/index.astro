---
import BaseHead from '../../components/BaseHead.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categoryLabel = (cat: string | undefined) => {
  const map: Record<string, string> = {
    nikkei: '日経ノート',
    deep: '深掘りノート',
    memo: '投資メモ',
    glossary: '用語解説',
    weekly: '週次振り返り',
    guide: '投資ガイド',
  };
  return cat ? (map[cat] ?? cat) : '記事';
};
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title="記事一覧" description={SITE_DESCRIPTION} />
    <style>
      :root {
        --navy: #10233f;
        --navy-2: #2c4a74;
        --blue: #eaf2fb;
        --blue-2: #f5f8fc;
        --text: #1c2534;
        --muted: #5d6b80;
        --border: #e2e7ee;
        --white: #ffffff;
        --shadow: 0 1px 2px rgba(16, 35, 63, .05);
        --radius: 10px;
        --serif: "Noto Serif JP", "Yu Mincho", "Hiragino Mincho ProN", serif;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body { overflow-x: clip; }

      body {
        font-family: "Hiragino Kaku Gothic ProN", "Hiragino Sans", "Yu Gothic Medium", "Yu Gothic", "Noto Sans JP", "Meiryo", sans-serif;
        color: var(--text);
        background: #f7f9fb;
        line-height: 1.85;
      }

      a { color: inherit; text-decoration: none; }

      /* ヘッダーはSiteHeaderコンポーネントで管理 */

      /* パンくず */
      .breadcrumb {
        max-width: 1200px;
        margin: 0 auto;
        padding: 14px 20px 0;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: var(--muted);
      }

      .breadcrumb a { color: var(--navy); }

      /* メインコンテンツ */
      .page-inner {
        max-width: 1200px;
        margin: 28px auto 60px;
        padding: 0 20px;
      }

      .page-title {
        font-family: var(--serif);
        font-size: 22px;
        font-weight: 700;
        color: var(--text);
        padding-bottom: 10px;
        border-bottom: 2px solid var(--navy);
        margin-bottom: 20px;
      }

      /* カテゴリータブ */
      .category-tabs {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 28px;
      }

      .category-tab {
        display: inline-block;
        padding: 6px 16px;
        border-radius: 999px;
        border: 1px solid var(--border);
        font-size: 13px;
        font-weight: 600;
        color: var(--muted);
        background: var(--white);
        transition: all .15s;
      }

      .category-tab:hover,
      .category-tab.active {
        background: var(--navy);
        color: #fff;
        border-color: var(--navy);
      }

      /* 記事リスト（罫線の索引形式） */
      .post-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0;
      }

      .post-card {
        background: transparent;
        border-bottom: 1px solid var(--border);
        padding: 16px 4px;
        transition: background .15s;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      .post-card:hover {
        background: #f0f5fa;
      }

      .post-meta {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .badge {
        background: #e8eef6;
        color: var(--navy);
        border-radius: 3px;
        padding: 1px 9px;
        font-size: 11px;
        font-weight: 700;
      }

      .post-date {
        font-size: 12px;
        color: var(--muted);
        font-variant-numeric: tabular-nums;
      }

      .post-title {
        font-size: 14.5px;
        font-weight: 600;
        color: var(--text);
        line-height: 1.65;
      }

      .post-description {
        font-size: 12.5px;
        color: var(--muted);
        line-height: 1.7;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      /* フッター */
      footer {
        background: var(--navy);
        color: #dce7f6;
        padding: 28px 20px;
      }

      .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
        font-size: 13px;
      }

      .footer-inner a { color: #9ec4e8; }

      /* カレンダーフィルターバナー */
      .cal-filter-banner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        background: var(--blue);
        border: 1px solid #c5d9f0;
        border-radius: 12px;
        padding: 10px 16px;
        margin-bottom: 18px;
        font-size: 14px;
        font-weight: 700;
        color: var(--navy);
      }
      .cal-filter-clear {
        font-size: 13px;
        font-weight: 600;
        color: var(--muted);
        white-space: nowrap;
      }
      .cal-filter-clear:hover { color: var(--navy); }

      /* レスポンシブ */
      @media (max-width: 860px) {
        nav { display: none; }
        .post-grid { grid-template-columns: 1fr; }
        .post-title { font-size: 16px; }
        .post-description { font-size: 14px; }
      }
    </style>
  </head>
  <body>

    <SiteHeader />

    <div class="breadcrumb">
      <a href="/">ホーム</a>
      <span>›</span>
      <span>記事一覧</span>
    </div>

    <div class="page-inner">
      <h1 class="page-title">記事一覧</h1>

      <div class="category-tabs">
        <a class="category-tab active" href="/blog">すべて</a>
        <a class="category-tab" href="/blog/category/nikkei">日経ノート</a>
        <a class="category-tab" href="/blog/category/deep">深掘りノート</a>
        <a class="category-tab" href="/blog/category/memo">投資メモ</a>
        <a class="category-tab" href="/blog/category/glossary">用語解説</a>
      </div>

      <!-- カレンダーフィルター中のバナー（JS で表示） -->
      <div id="cal-filter-banner" style="display:none;" class="cal-filter-banner">
        <span id="cal-filter-label"></span>
        <a href="/blog/" class="cal-filter-clear">× フィルターを解除</a>
      </div>

      <div class="post-grid" id="post-grid">
        {posts.map((post) => (
          <a class="post-card" href={`/blog/${post.id}/`}
            data-date={post.data.pubDate.toISOString().slice(0,10)}
            data-month={post.data.pubDate.toISOString().slice(0,7)}>
            <div class="post-meta">
              <span class="badge">{categoryLabel(post.data.category)}</span>
              <span class="post-date">
                {post.data.pubDate.getFullYear()}年{post.data.pubDate.getMonth() + 1}月{post.data.pubDate.getDate()}日
              </span>
            </div>
            <p class="post-title">{post.data.title}</p>
            {post.data.description && (
              <p class="post-description">{post.data.description}</p>
            )}
          </a>
        ))}
      </div>
      <p id="no-results" style="display:none; color:var(--muted); font-size:14px; margin-top:20px;">該当する記事が見つかりませんでした。</p>
    </div>

    <SiteFooter />

  <script>
    (function () {
      const params = new URLSearchParams(window.location.search);
      const filterDate  = params.get('date');
      const filterMonth = params.get('month');
      if (!filterDate && !filterMonth) return;

      const cards     = document.querySelectorAll('#post-grid .post-card');
      const banner    = document.getElementById('cal-filter-banner');
      const label     = document.getElementById('cal-filter-label');
      const noResults = document.getElementById('no-results');
      let visible = 0;

      cards.forEach(card => {
        const d = card.getAttribute('data-date')  ?? '';
        const mo = card.getAttribute('data-month') ?? '';
        const show = filterDate ? d === filterDate : mo === filterMonth;
        (card as HTMLElement).style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (banner && label) {
        banner.style.display = 'flex';
        if (filterDate) {
          const [y, mo, day] = filterDate.split('-');
          label.textContent = `${y}年${Number(mo)}月${Number(day)}日の記事（${visible}件）`;
        } else if (filterMonth) {
          const [y, mo] = filterMonth.split('-');
          label.textContent = `${y}年${Number(mo)}月の記事（${visible}件）`;
        }
      }

      if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
    })();
  </script>
  </body>
</html>
