---
import { type CollectionEntry, getCollection } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import GlossaryPost from '../../layouts/GlossaryPost.astro';
import { render } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

const plainText = (post.body ?? '').replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
const readTimeMin = Math.max(1, Math.ceil(plainText.length / 500));
---

{post.data.category === 'glossary' ? (
  <GlossaryPost {...post.data} readTimeMin={readTimeMin}>
    <Content />
  </GlossaryPost>
) : (
  <BlogPost {...post.data} readTimeMin={readTimeMin}>
    <Content />
  </BlogPost>
)}
